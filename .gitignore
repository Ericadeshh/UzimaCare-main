# Create .gitignore file
@"
# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/
/build

# production
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env.development
.env.production
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# convex
convex/_generated/
" | Out-File -FilePath .gitignore -Encoding utf8